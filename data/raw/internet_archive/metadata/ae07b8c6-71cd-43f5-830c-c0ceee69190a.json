    "\u0642\u0627\u0631\u0626\u0627 \u062a\u062d\u0645\u064a\u0644 \u0643\u062a\u0627\u0628 \u0635\u0648\u062a\u064a (\u0645\u0633\u0645\u0648\u0639) \u0634\u0631\u062d \u0627\u0644\u0623\u0631\u0628\u0639\u064a\u0646 \u0627\u0644\u0646\u0648\u0648\u064a\u0629 \u0644\u0625\u0628\u0646 \u062f\u0642\u064a\u0642 \u0627\u0644\u0639\u0640\u064a\u062f \u0628\u064a \u062f\u064a \u0627\u0641 \u0627\u0644\u0645\u0643\u062a\u0628\u0629 \u0627\u0644\u0635\u0648\u062a\u064a\u0629 \u0627\u0644\u0645\u0633\u0645\u0648\u0639\u0629 \u0643\u062a\u0627\u0628 \u0645\u0633\u0645\u0648\u0639 \u0635\u0648\u062a\u064a \u0642\u0631\u0627\u0621\u0629 \u0635\u0648\u062a\u064a\u0629 book 40 nawawya ibn daqeq alaaed mp3 \u062a\u062d\u0645\u064a\u0644 \u0643\u062a\u0627\u0628 \u0645\u0633\u0645\u0648\u0639 (\u0635\u0648\u062a\u064a) : \u0625\u0633\u062a\u0645\u062a\u0639 \u0628\u062d\u064a\u0627\u062a\u0643 \u0644\u0644\u0634\u064a\u062e \u0645\u062d\u0645\u062f \u0628\u0646 \u0639\u0628\u062f \u0627\u0644\u0631\u062d\u0645\u0646 \u0627\u0644\u0639\u0631\u064a\u0641\u064a \u0628\u062c\u0648\u062f\u0629 \u0635\u0648\u062a \u0639\u0627\u0644\u064a\u0629 \u062a\u062d\u0645\u064a\u0644 \u0643\u062a\u0627\u0628 \u0645\u0633\u0645\u0648\u0639 (\u0635\u0648\u062a\u064a) : \u0627\u0644\u0628\u0627\u0639\u062b \u0627\u0644\u062d\u062b\u064a\u062b \u0634\u0631\u062d \u0627\u062e\u062a\u0635\u0627\u0631 \u0639\u0644\u0648\u0645 \u0627\u0644\u062d\u062f\u064a\u062b \u0644\u0627\u0628\u0646 \u0643\u062b\u064a\u0631 \u0634\u0631\u062d \u0627\u0644\u0634\u064a\u062e \u0627\u062d\u0645\u062f \u0634\u0627\u0643"
